{
  "name": "boilerplate/laravel-backend",
  "description": "Laravel microservice with DDD, Clean Architecture, Supabase, SQS, Swagger",
  "type": "project",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^11.0",
    "tymon/jwt-auth": "^2.1",
    "aws/aws-sdk-php": "^3.300",
    "guzzlehttp/guzzle": "^7.8",
    "doctrine/dbal": "^3.7",
    "darkaonline/l5-swagger": "^8.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "laravel/pint": "^1.13",
    "fakerphp/faker": "^1.23",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Domain\\": "app/Domain/",
      "Application\\": "app/Application/",
      "Infrastructure\\": "app/Infrastructure/",
      "Modules\\": "Modules/"
    }
  },
  "scripts": {
    "test": "./vendor/bin/phpunit",
    "lint": "./vendor/bin/pint --test",
    "format": "./vendor/bin/pint"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}