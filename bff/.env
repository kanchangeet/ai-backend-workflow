APP_NAME="BFF"
APP_ENV=local
APP_KEY=base64:nfJEspLk5/ZJG8/KUY7es0+GfY18gHCinnxy7+YHuE8=
APP_DEBUG=true
APP_URL=http://localhost:9090

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Backend Service ──────────────────────────────────────────────────────────
# Local dev (both running natively):
# BACKEND_URL=http://localhost:8000

# Docker (BFF + Backend on shared network):
BACKEND_URL=http://laravel_nginx
BACKEND_TIMEOUT=10

# ─── Swagger ──────────────────────────────────────────────────────────────────
L5_SWAGGER_GENERATE_ALWAYS=true
L5_SWAGGER_CONST_HOST=http://localhost:9080
L5_SWAGGER_UI_PERSIST_AUTHORIZATION=true

# ─── Cache / Session ─────────────────────────────────────────────────────────
CACHE_DRIVER=array
SESSION_DRIVER=cookie
QUEUE_CONNECTION=sync
