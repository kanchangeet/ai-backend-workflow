APP_NAME="BFF"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://bff.yourdomain.com

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── Backend Service ──────────────────────────────────────────────────────────
BACKEND_URL=https://api.yourdomain.com
BACKEND_TIMEOUT=10

# ─── Cache / Session ─────────────────────────────────────────────────────────
CACHE_DRIVER=array
SESSION_DRIVER=cookie
QUEUE_CONNECTION=sync

# ─── CORS ────────────────────────────────────────────────────────────────────
# Configure in config/cors.php
# ALLOWED_ORIGINS=https://app.yourdomain.com
